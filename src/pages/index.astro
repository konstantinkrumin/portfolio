---
import Component from "../components/Component.astro";
import Experience from "../components/experience/index.astro";
import Nav from "../components/nav/index.astro";
import { EXPERIENCE } from "../data/experience";
import { SOCIALS } from "../data/socials";
import Layout from "../layouts/Layout.astro";
---

<Layout title="Konstantin Krumin">
  <div class="relative hero isolate z-10">
    <div
      class="mx-auto min-h-screen max-w-screen-2xl px-6 py-12 font-sans md:px-12 md:py-20 lg:px-24 lg:py-0"
    >
      <div class="lg:flex lg:justify-between lg:gap-4">
        <header
          class="lg:sticky lg:top-0 lg:flex lg:max-h-screen lg:w-1/2 lg:flex-col lg:py-24"
        >
          <div>
            <div
              class="flex flex-col items-center gap-4 text-center lg:flex-row lg:items-start lg:text-left"
            >
              <img
                src="/avatar.jpg"
                alt="Konstantin Krumin"
                class="h-16 w-16"
              />
              <div>
                <a
                  href="/"
                  class="block bg-gradient-to-b from-stone-900 to-stone-500 bg-clip-text text-4xl font-bold tracking-tight text-transparent lg:text-5xl dark:from-neutral-50 dark:to-neutral-400 dark:bg-opacity-50"
                >
                  <h1>Konstantin Krumin</h1>
                </a>
                <h2
                  class="mt-2 text-sm font-medium text-stone-600 lg:text-lg dark:text-neutral-400"
                >
                  Senior Developer @ Intellitix
                </h2>

                <div
                  class="mt-4 flex items-center justify-center gap-4 lg:justify-start"
                >
                  {
                    SOCIALS.length && (
                      <ul
                        class="flex items-center gap-x-3"
                        aria-label="Social media"
                      >
                        {SOCIALS.map((social) => (
                          <li class="rounded p-1 text-xs" data-ccursor>
                            <a
                              class="block text-stone-600 transition hover:text-stone-900 dark:text-neutral-400 dark:hover:text-slate-200"
                              href={social.url}
                              target="_blank"
                              rel="noreferrer noopener"
                              aria-label={`${social.name} (opens in a new tab)`}
                            >
                              <span class="sr-only">{social.name}</span>
                              {<Component component={social.icon} />}
                            </a>
                          </li>
                        ))}
                      </ul>
                    )
                  }
                  <a
                    data-ccursor
                    href="mailto:konstantin.krumin@gmail.com"
                    class="group inline-flex items-center gap-x-2 rounded-md border border-stone-300/70 bg-white/70 p-2 px-3 py-2.5 text-sm font-semibold text-stone-800 shadow backdrop-blur-xl transition-all hover:border-stone-400/80 dark:border-neutral-700 dark:border-opacity-50 dark:bg-neutral-400/10 dark:text-white dark:hover:border-opacity-0"
                  >
                    <span>Email me</span>
                    <span
                      class="h-2 w-2 animate-pulse rounded-full bg-green-400 duration-1000"
                    >
                    </span>
                  </a>
                </div>
              </div>
            </div>

            <Nav />
          </div>
        </header>

        <main id="content" class="pt-24 lg:w-1/2 lg:py-24">
          <section
            id="about"
            class="mb-16 scroll-mt-16 md:mb-24 lg:mb-36 lg:scroll-mt-24"
            aria-label="About me"
          >
            <div
              class="sticky top-0 z-20 -mx-6 mb-4 w-screen px-6 py-3 backdrop-blur-lg md:-mx-12 md:px-12 lg:sr-only lg:relative lg:top-auto lg:mx-auto lg:w-full lg:px-0 lg:py-0 lg:opacity-0"
            >
              <h2
                class="text-sm font-bold uppercase tracking-widest text-stone-800 lg:sr-only dark:text-neutral-200"
              >
                About
              </h2>
            </div>
            <div>
              <div class="relative z-10 mb-4 space-y-4 text-stone-900 dark:text-neutral-300">
                <p>
                  I'm a senior software engineer focused on mobile and frontend
                  development, building production apps with TypeScript, React
                  Native, and React. I work across the full stack when needed —
                  from intuitive UIs to the APIs and integrations behind them —
                  with experience shipping reliable software in fast-moving,
                  real-time environments.
                </p>

                <p>
                  Currently at Intellitix, building event technology used on-site
                  at scale. Open to interesting projects and conversations
                  around mobile, frontend, and product engineering.
                </p>
              </div>
            </div>
          </section>
          <section
            id="experience"
            class="mb-0 scroll-mt-16 md:mb-0 lg:mb-0 lg:scroll-mt-24"
            aria-label="Work experience"
          >
            <div
              class="sticky top-0 z-20 -mx-6 mb-4 w-screen px-6 py-3 backdrop-blur-lg md:-mx-12 md:px-12 lg:sr-only lg:relative lg:top-auto lg:mx-auto lg:w-full lg:px-0 lg:py-0 lg:opacity-0"
            >
              <h2
                class="text-sm font-bold uppercase tracking-widest text-stone-800 lg:sr-only dark:text-neutral-200"
              >
                Experience
              </h2>
            </div><div>
              <ol class="group/list space-y-12">
                {EXPERIENCE.map((experience) => <Experience {...experience} />)}
              </ol>
            </div>
          </section>
          <section
            id="resume"
            class="mt-6 scroll-mt-16 pb-8 sm:grid sm:grid-cols-8 sm:gap-8 md:gap-4 lg:mt-10 lg:scroll-mt-24 lg:pb-24"
            aria-label="Resume"
          >
            <h2 class="sr-only">Resume</h2>
            <div class="hidden sm:block sm:col-span-2" aria-hidden="true"></div>
            <div class="sm:col-span-6 lg:flex lg:justify-end">
              <a
                data-ccursor
                class="group -ml-3 inline-flex items-center rounded px-3 py-2 font-semibold leading-tight text-stone-900 dark:text-neutral-200 lg:-mr-3"
              aria-label="View Full Résumé"
              target="_blank"
              rel="noreferrer noopener"
              href="./resume.pdf"
            >
              <span>
                <span
                  class="border-b border-transparent pb-px transition group-hover:border-stone-500 motion-reduce:transition-none dark:group-hover:border-neutral-300"
                >
                  View Full
                </span>
                <span class="whitespace-nowrap">
                  <span
                    class="border-b border-transparent pb-px transition group-hover:border-stone-500 motion-reduce:transition-none dark:group-hover:border-neutral-300"
                  >
                    Resume
                  </span>
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                    class="ml-1 inline-block h-4 w-4 shrink-0 -translate-y-px transition-transform group-hover:translate-x-2 group-focus-visible:translate-x-2 motion-reduce:transition-none"
                    aria-hidden="true"
                    ><path
                      fill-rule="evenodd"
                      d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z"
                      clip-rule="evenodd"></path></svg
                ></span
              ></span
            ></a>
            </div>
          </section>
        </main>
      </div>
    </div>
  </div>
</Layout>

<style scoped>
  @keyframes fadeIn {
    0% {
      opacity: 0;
    }
    100% {
      opacity: 1;
    }
  }

  .hero {
    background-image: url(/pattern.svg);
    background-position: top center;
    background-repeat: no-repeat;
    overflow-y: visible;
    overflow-x: clip;
  }

  :global(html:not(.dark)) .hero {
    background-size: 100% auto;
    opacity: 1;
  }

  :global(html:not(.dark)) .hero::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 0;
    background: linear-gradient(
      to bottom,
      rgb(250 250 249 / 0.85),
      rgb(250 250 249 / 0.95)
    );
    pointer-events: none;
  }

  .hero > * {
    position: relative;
    z-index: 1;
  }

  /*
  .hero {
    animation: fadeIn 3s;
  }
   */
</style>
