---
import { NAV_ITEMS } from "../../data/nav";
---

<nav class="mt-16 hidden lg:block" aria-label="In-page navigation">
  <ul class="flex flex-col gap-1">
    {
      NAV_ITEMS.map(({ label, href }) => (
        <li>
          <a
            data-nav-link
            href={href}
            class="nav-link group flex items-center py-2 text-xs font-bold uppercase tracking-widest text-stone-500 transition-colors duration-300 ease-out hover:text-stone-800 focus-visible:text-stone-800 dark:text-neutral-500 dark:hover:text-neutral-200 dark:focus-visible:text-neutral-200"
          >
            <span class="nav-indicator mr-4 h-px w-8 bg-stone-300 transition-all duration-300 ease-out group-hover:bg-stone-600 group-focus-visible:bg-stone-600 dark:bg-neutral-700 dark:group-hover:bg-neutral-200 dark:group-focus-visible:bg-neutral-200" />
            {label}
          </a>
        </li>
      ))
    }
  </ul>
</nav>

<style>
  .nav-link.active {
    color: var(--nav-active);
    transition: color 0.3s ease-out;
  }

  .nav-link.active .nav-indicator {
    width: 4rem;
    background-color: var(--nav-active);
    transition:
      width 0.3s ease-out,
      background-color 0.3s ease-out;
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-link,
    .nav-indicator {
      transition: none;
    }
  }
</style>
